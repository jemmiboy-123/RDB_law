<%- include('../partials/header', {title: 'Clients'}) %>
<div class="topbar">
  <h1>Clients</h1>
  <div class="actions"><a class="btn" href="/clients/new">New Client</a></div>
</div>
<form class="card inline" method="get" style="margin-bottom:12px;">
  <input name="q" placeholder="Search client" value="<%= query %>" />
  <button type="submit">Filter</button>
</form>
<section class="card table-wrap">
<table><thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Cases</th><th></th></tr></thead><tbody>
  <% if (clients.length) { clients.forEach(c => { %>
  <tr>
    <td><a href="/clients/<%= c.id %>"><%= c.full_name %></a></td>
    <td><%= c.email || '' %></td><td><%= c.phone || '' %></td><td><%= c.case_count %></td>
    <td><a class="btn btn-ghost" href="/clients/<%= c.id %>/edit">Edit</a></td>
  </tr>
  <% }) } else { %><tr><td colspan="5">No clients yet.</td></tr><% } %>
</tbody></table>
</section>
<%- include('../partials/footer') %>
