<%- include('../partials/header', {title: 'Notifications'}) %>
<div class="topbar"><h1>Notifications</h1></div>
<div class="grid-2">
  <section class="card stack">
    <h3>Due This Week</h3>
    <div class="table-wrap"><table><thead><tr><th>When</th><th>Case</th><th>Title</th></tr></thead><tbody>
      <% if (reminders.length) { reminders.forEach(r => { %>
      <tr><td><%= fmtDateTime(r.due_date) %></td><td><%= r.case_ref %></td><td><%= r.title %></td></tr>
      <% }) } else { %><tr><td colspan="3">No reminders.</td></tr><% } %>
    </tbody></table></div>
  </section>
  <section class="card stack">
    <h3>Overdue Tasks</h3>
    <div class="table-wrap"><table><thead><tr><th>Due</th><th>Case</th><th>Task</th></tr></thead><tbody>
      <% if (overdue_tasks.length) { overdue_tasks.forEach(t => { %>
      <tr><td><%= fmtDate(t.due_date) %></td><td><%= t.case_ref %></td><td><%= t.title %></td></tr>
      <% }) } else { %><tr><td colspan="3">No overdue tasks.</td></tr><% } %>
    </tbody></table></div>
  </section>
</div>
<%- include('../partials/footer') %>
