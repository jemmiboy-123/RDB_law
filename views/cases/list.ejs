<%- include('../partials/header', {title: 'Cases'}) %>
<div class="topbar">
  <h1>Cases</h1>
  <% if (['admin','lawyer','staff'].includes(user.role)) { %><a class="btn" href="/cases/new">New Case</a><% } %>
</div>
<form method="get" class="card inline" style="margin-bottom:12px;">
  <input name="q" placeholder="Search case title" value="<%= search %>">
  <select name="status">
    <option value="">All Statuses</option>
    <option value="open" <%= status==='open' ? 'selected' : '' %>>Open</option>
    <option value="pending" <%= status==='pending' ? 'selected' : '' %>>Pending</option>
    <option value="closed" <%= status==='closed' ? 'selected' : '' %>>Closed</option>
  </select>
  <button type="submit">Apply</button>
</form>
<section class="card table-wrap">
  <table><thead><tr><th>Reference</th><th>Title</th><th>Client</th><th>Status</th><th>Lawyers</th></tr></thead><tbody>
  <% if (cases.length) { cases.forEach(c => { %>
  <tr>
    <td><a href="/cases/<%= c.id %>"><%= c.reference_number %></a></td>
    <td><%= c.title %></td>
    <td><%= c.client ? c.client.full_name : '' %></td>
    <td><span class="badge <%= c.status %>"><%= c.status %></span></td>
    <td><%= c.lawyers.map(l => l.full_name).join(', ') || '-' %></td>
  </tr>
  <% }) } else { %><tr><td colspan="5">No cases found.</td></tr><% } %>
  </tbody></table>
</section>
<%- include('../partials/footer') %>
