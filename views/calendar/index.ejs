<%- include('../partials/header', {title: 'Calendar & Deadlines'}) %>
<div class="topbar"><h1>Calendar &amp; Deadlines</h1></div>
<% if (['admin','lawyer','staff'].includes(user.role)) { %>
<form method="post" class="card form-grid" style="margin-bottom:12px;">
  <div class="grid-2">
    <label>Case<select name="case_id"><% cases.forEach(c => { %><option value="<%= c.id %>"><%= c.reference_number %></option><% }) %></select></label>
    <label>Type<select name="kind"><option value="court_date">Court Date</option><option value="deadline">Deadline</option></select></label>
  </div>
  <div class="grid-2">
    <label>Title<input name="title" required></label>
    <label>Date &amp; Time<input type="datetime-local" name="due_date" required></label>
  </div>
  <div><button type="submit">Add Event</button></div>
</form>
<% } %>
<section class="card table-wrap">
<table><thead><tr><th>Date</th><th>Case</th><th>Type</th><th>Title</th></tr></thead><tbody>
  <% if (deadlines.length) { deadlines.forEach(d => { %>
  <tr><td><%= fmtDateTime(d.due_date) %></td><td><%= d.case_ref %></td><td><%= d.kind %></td><td><%= d.title %></td></tr>
  <% }) } else { %><tr><td colspan="4">No calendar events yet.</td></tr><% } %>
</tbody></table>
</section>
<%- include('../partials/footer') %>
