# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=

# Admin account (used only on first startup when no admin exists)
ADMIN_EMAIL=admin@lawfirm.local
ADMIN_PASSWORD=

# Database (defaults to local SQLite)
DATABASE_URL=sqlite:///lawfirm.db

# Server
PORT=5000

# Email (optional — leave blank to disable email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lawfirm.local
